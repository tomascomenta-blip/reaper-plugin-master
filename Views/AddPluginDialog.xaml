<Window x:Class="ReaperPluginManager.Views.AddPluginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Agregar Plugin"
        Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource SurfaceDark}"
        Style="{StaticResource MaterialDesignWindow}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Agregar Nuevo Plugin"
                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                       Foreground="White"/>
            <TextBlock Text="Completa los datos del plugin a instalar"
                       Foreground="#78909C" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Formulario -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBox materialDesign:HintAssist.Hint="Nombre del plugin *"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"/>

                <TextBox materialDesign:HintAssist.Hint="Desarrollador"
                         Text="{Binding Developer, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             materialDesign:HintAssist.Hint="Versión"
                             Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    <ComboBox Grid.Column="2"
                              materialDesign:HintAssist.Hint="Formato *"
                              SelectedItem="{Binding Format}"
                              ItemsSource="{Binding AvailableFormats}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                </Grid>

                <!-- URL con botón de examinar -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             materialDesign:HintAssist.Hint="URL de descarga (HTTPS) *"
                             Text="{Binding DownloadUrl, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    <Button Grid.Column="1" Margin="8,0,0,0"
                            Command="{Binding BrowseLocalFileCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            ToolTip="Seleccionar archivo local">
                        <materialDesign:PackIcon Kind="FolderOpen"/>
                    </Button>
                </Grid>

                <TextBox materialDesign:HintAssist.Hint="Hash SHA-256 esperado (opcional, recomendado)"
                         Text="{Binding ExpectedSHA256, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"
                         FontFamily="Consolas" FontSize="12"/>

                <TextBox materialDesign:HintAssist.Hint="Descripción"
                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AcceptsReturn="True" Height="80"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              materialDesign:HintAssist.Hint="Categoría"
                              SelectedItem="{Binding Category}"
                              ItemsSource="{Binding AvailableCategories}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    <TextBox Grid.Column="2"
                             materialDesign:HintAssist.Hint="Tags (coma separado)"
                             Text="{Binding TagsText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                </Grid>

                <!-- Advertencia de seguridad -->
                <materialDesign:Card Background="#1A2A1A" Padding="12" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ShieldCheck" Foreground="{StaticResource SafeGreen}"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#A5D6A7">
                            El plugin pasará por el pipeline completo de seguridad:
                            SHA-256 → Firma Digital → Windows Defender → Sandbox
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- Botones -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar"
                    IsCancel="True"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="Cancel_Click"
                    Margin="0,0,8,0"/>
            <Button Command="{Binding AddAndInstallCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    IsDefault="True">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Download" Margin="0,0,4,0"/>
                    <TextBlock Text="Agregar e Instalar"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
