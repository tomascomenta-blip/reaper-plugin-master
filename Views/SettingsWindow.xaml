<Window x:Class="ReaperPluginManager.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Configuración" Height="540" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource SurfaceDark}"
        Style="{StaticResource MaterialDesignWindow}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configuración"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   Margin="0,0,0,16" Foreground="White"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Rutas de plugins -->
                <TextBlock Text="DIRECTORIOS DE PLUGINS"
                           Style="{StaticResource MaterialDesignOverlineTextBlock}"
                           Foreground="#78909C" Margin="0,0,0,8"/>
                <TextBox materialDesign:HintAssist.Hint="Directorio VST2"
                         Text="{Binding VST2Path}" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12"/>
                <TextBox materialDesign:HintAssist.Hint="Directorio VST3"
                         Text="{Binding VST3Path}" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12"/>
                <TextBox materialDesign:HintAssist.Hint="Directorio JSFX"
                         Text="{Binding JSFXPath}" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12"/>
                <TextBox materialDesign:HintAssist.Hint="Ruta de REAPER"
                         Text="{Binding ReaperPath}" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,20"/>

                <Separator Margin="0,0,0,16"/>

                <!-- Comportamiento -->
                <TextBlock Text="COMPORTAMIENTO"
                           Style="{StaticResource MaterialDesignOverlineTextBlock}"
                           Foreground="#78909C" Margin="0,0,0,8"/>

                <ToggleButton IsChecked="{Binding EnableSandbox}"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              HorizontalAlignment="Left"/>
                <TextBlock Text="Habilitar sandbox de prueba" Margin="0,4,0,12"/>

                <ToggleButton IsChecked="{Binding EnableDefender}"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              HorizontalAlignment="Left"/>
                <TextBlock Text="Escanear con Windows Defender" Margin="0,4,0,12"/>

                <ToggleButton IsChecked="{Binding CheckUpdatesOnStart}"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              HorizontalAlignment="Left"/>
                <TextBlock Text="Verificar actualizaciones al inicio" Margin="0,4,0,20"/>

                <Separator Margin="0,0,0,16"/>

                <!-- Directorios del sistema -->
                <TextBlock Text="SISTEMA"
                           Style="{StaticResource MaterialDesignOverlineTextBlock}"
                           Foreground="#78909C" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox materialDesign:HintAssist.Hint="Directorio de logs"
                             Text="{Binding LogDirectory}" IsReadOnly="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Width="340"/>
                    <Button Command="{Binding OpenLogDirectoryCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}" Margin="8,0,0,0">
                        <materialDesign:PackIcon Kind="FolderOpen"/>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBox materialDesign:HintAssist.Hint="Directorio de cuarentena"
                             Text="{Binding QuarantineDirectory}" IsReadOnly="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Width="340"/>
                    <Button Command="{Binding OpenQuarantineDirectoryCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}" Margin="8,0,0,0">
                        <materialDesign:PackIcon Kind="FolderOpen"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" IsCancel="True"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Guardar" IsDefault="True"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding SaveSettingsCommand}"/>
        </StackPanel>
    </Grid>
</Window>
