                                    <TextBlock Text="¿Qué es esto?" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="HelpNav1" Click="HelpNav_Click" Tag="1"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="12,8" Foreground="#78909C"
                                    BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckboxMarkedCircleOutline" Width="16" Height="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Requisitos" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="HelpNav2" Click="HelpNav_Click" Tag="2"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="12,8" Foreground="#78909C"
                                    BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Hammer" Width="16" Height="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Compilar el programa" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="HelpNav3" Click="HelpNav_Click" Tag="3"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="12,8" Foreground="#78909C"
                                    BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Agregar plugins" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="HelpNav4" Click="HelpNav_Click" Tag="4"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
