                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Compilar el VSTHost (sandbox, opcional)" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                            <Border Background="#0A0A12" CornerRadius="4" Padding="12,10">
                                                <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#90CBF9" TextWrapping="Wrap">cd VSTHost/PluginTestHost&#xA;dotnet publish PluginTestHost.csproj -c Release -r win-x64 --self-contained true /p:PublishSingleFile=true -o ../../publish/VSTHost/</TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </StackPanel>

                            <!-- SECCIÓN 3: Agregar plugins -->
                            <StackPanel x:Name="HelpSec3" Visibility="Collapsed">
                                <TextBlock Text="Agregar plugins al gestor"
                                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                           Foreground="White" Margin="0,0,0,6"/>
                                <TextBlock Text="Cómo registrar tus archivos VST en la base de datos"
                                           Foreground="#78909C" FontSize="13" Margin="0,0,0,20"/>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0" VerticalAlignment="Top">
