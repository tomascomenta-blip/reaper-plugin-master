                                    </StackPanel></Grid>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0" VerticalAlignment="Top">
                                        <TextBlock Text="2" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/></Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text='Clic en "Agregar Plugin" (botón + en el header)' FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">El botón está en la barra superior de la ventana junto a la búsqueda.</TextBlock>
                                    </StackPanel></Grid>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0" VerticalAlignment="Top">
                                        <TextBlock Text="3" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/></Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Seleccionar el archivo del plugin" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">Navega hasta el .dll (VST2), .vst3 (VST3) o .jsfx y selecciónalo en el explorador.</TextBlock>
                                    </StackPanel></Grid>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0" VerticalAlignment="Top">
                                        <TextBlock Text="4" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/></Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Escaneo automático de seguridad" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">El programa escaneará el archivo con Windows Defender y verificará su firma digital. Verás el resultado en el panel derecho de detalle.</TextBlock>
                                    </StackPanel></Grid>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,0">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0" VerticalAlignment="Top">
                                        <TextBlock Text="5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/></Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Plugin registrado en la base de datos" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">El plugin aparece en la lista con nombre, tipo, tamaño y estado de seguridad. Se guarda en %LOCALAPPDATA%\ReaperPluginManager\plugins.db</TextBlock>
                                    </StackPanel></Grid>
                                </materialDesign:Card>
                            </StackPanel>

                            <!-- SECCIÓN 4: Instalar en REAPER -->
                            <StackPanel x:Name="HelpSec4" Visibility="Collapsed">
                                <TextBlock Text="Instalar plugins en REAPER"
                                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                           Foreground="White" Margin="0,0,0,6"/>
                                <TextBlock Text="Cómo copiar el plugin al directorio correcto y que REAPER lo detecte"
                                           Foreground="#78909C" FontSize="13" Margin="0,0,0,20"/>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0" VerticalAlignment="Top">
                                        <TextBlock Text="1" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/></Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Seleccionar el plugin en la lista central" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">Haz clic sobre el plugin que quieres instalar. Se abrirá el panel de detalle a la derecha.</TextBlock>
                                    </StackPanel></Grid>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0" VerticalAlignment="Top">
                                        <TextBlock Text="2" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/></Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text='Clic en "Instalar"' FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap" Margin="0,0,0,8">El programa copia el .dll/.vst3 al directorio de plugins de REAPER automáticamente. Las rutas destino dependen de los permisos:</TextBlock>
                                        <Border Background="#0A0A12" CornerRadius="4" Padding="12,10">
                                            <StackPanel>
                                                <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#90CBF9" Margin="0,0,0,4">Sin admin → %APPDATA%\REAPER\Plugins</TextBlock>
                                                <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#CE93D8" Margin="0,0,0,4">Con admin → C:\Program Files\VSTPlugins</TextBlock>
                                                <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#CE93D8">Con admin (VST3) → C:\Program Files\Common Files\VST3</TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel></Grid>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0" VerticalAlignment="Top">
                                        <TextBlock Text="3" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/></Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Configurar la ruta de plugins en REAPER" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">Si usas un directorio personalizado, en REAPER ve a:</TextBlock>
                                        <Border Background="#0A0A12" CornerRadius="4" Padding="12,10" Margin="0,8,0,0">
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#90CBF9">Opciones → Preferencias → VST → (agregar ruta)</TextBlock>
                                        </Border>
                                    </StackPanel></Grid>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0" VerticalAlignment="Top">
                                        <TextBlock Text="4" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/></Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Reescanear plugins en REAPER" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">Abre REAPER y haz clic en:</TextBlock>
                                        <Border Background="#0A0A12" CornerRadius="4" Padding="12,10" Margin="0,8,0,0">
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#90CBF9">Opciones → Preferencias → VST → "Reescanear / encontrar nuevos plugins VST"</TextBlock>
                                        </Border>
                                    </StackPanel></Grid>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0" VerticalAlignment="Top">
                                        <TextBlock Text="5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/></Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Usar el plugin en tus proyectos" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">El plugin ya aparecerá en el menú FX de REAPER al agregar un track. Ve a la cadena de efectos de un track y búscalo por nombre.</TextBlock>
                                    </StackPanel></Grid>
                                </materialDesign:Card>
                                <materialDesign:Card Background="#1B3A2A" Padding="14">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Lightbulb" Foreground="{StaticResource SuspiciousAmber}"
                                                                 Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap" VerticalAlignment="Center">
                                            <Run FontWeight="Bold" Text="Consejo:" Foreground="White"/>
                                            <Run Text=" Puedes configurar la ruta destino de instalación en la ventana Ajustes (icono ⚙️ arriba a la derecha)."/>
                                        </TextBlock>
                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>

                            <!-- SECCIÓN 5: Seguridad -->
                            <StackPanel x:Name="HelpSec5" Visibility="Collapsed">
                                <TextBlock Text="Escaneo de seguridad"
                                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                           Foreground="White" Margin="0,0,0,6"/>
                                <TextBlock Text="Cómo funciona la protección contra plugins maliciosos"
                                           Foreground="#78909C" FontSize="13" Margin="0,0,0,20"/>
                                <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap" Margin="0,0,0,16">
                                    Antes de instalar cualquier plugin, el programa realiza dos niveles de análisis automáticamente:
                                </TextBlock>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔬" FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="Nivel 1 — Windows Defender (MpCmdRun.exe)" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                            <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">El archivo se envía al motor de análisis de Windows Defender. Si contiene malware, el plugin se mueve automáticamente a la carpeta Quarantine.</TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔏" FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="Nivel 2 — Firma digital (WinVerifyTrust)" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                            <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">Se verifica si el .dll está firmado por un fabricante reconocido. Los plugins sin firma se marcan como "No verificado" pero pueden instalarse bajo tu responsabilidad.</TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </materialDesign:Card>
                                <TextBlock Text="COLORES DE ESTADO"
                                           Style="{StaticResource MaterialDesignOverlineTextBlock}"
                                           Foreground="#78909C" Margin="0,0,0,12"/>
                                <StackPanel>
                                    <materialDesign:Card Background="#1B3A2A" Padding="12" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CheckCircle" Foreground="{StaticResource SafeGreen}" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock Text="SEGURO" FontWeight="Bold" Foreground="{StaticResource SafeGreen}" FontSize="12"/>
                                                <TextBlock Text="Firmado digitalmente y sin amenazas detectadas." FontSize="12" Foreground="#B0BEC5"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </materialDesign:Card>
                                    <materialDesign:Card Background="#2A2200" Padding="12" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="AlertCircle" Foreground="{StaticResource SuspiciousAmber}" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock Text="ADVERTENCIA" FontWeight="Bold" Foreground="{StaticResource SuspiciousAmber}" FontSize="12"/>
                                                <TextBlock Text="Sin firma digital pero sin malware. Instala bajo tu criterio." FontSize="12" Foreground="#B0BEC5"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </materialDesign:Card>
                                    <materialDesign:Card Background="#2A0A0A" Padding="12">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ShieldOff" Foreground="{StaticResource BlockedRed}" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock Text="PELIGRO" FontWeight="Bold" Foreground="{StaticResource BlockedRed}" FontSize="12"/>
                                                <TextBlock Text="Malware detectado. Plugin enviado a cuarentena automáticamente." FontSize="12" Foreground="#B0BEC5"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </StackPanel>
                            </StackPanel>

                            <!-- SECCIÓN 6: FAQ -->
                            <StackPanel x:Name="HelpSec6" Visibility="Collapsed">
                                <TextBlock Text="Preguntas frecuentes"
                                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                           Foreground="White" Margin="0,0,0,6"/>
                                <TextBlock Text="Problemas comunes y cómo resolverlos"
                                           Foreground="#78909C" FontSize="13" Margin="0,0,0,20"/>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="⚠️ Aparece una advertencia de SmartScreen al abrir el .exe" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">El programa no tiene certificado EV. Es seguro: haz clic en "Más información" → "Ejecutar de todas formas".</TextBlock>
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="❌ Error: MaterialDesignThemes no encontrado al compilar" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">Las dependencias no se restauraron. Ejecuta: </TextBlock>
                                        <Border Background="#0A0A12" CornerRadius="4" Padding="10,8" Margin="0,6,0,0">
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#90CBF9">dotnet restore ReaperPluginManager.csproj</TextBlock>
                                        </Border>
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="🎵 REAPER no detecta el plugin aunque esté instalado" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">Ve a REAPER → Opciones → Preferencias → VST. Verifica que la ruta donde se instaló el plugin está en la lista. Si no, agrégala y haz clic en "Reescanear".</TextBlock>
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="🔒 Access denied al instalar en Program Files" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">Necesitas permisos de administrador. Haz clic derecho sobre ReaperPluginManager.exe → "Ejecutar como administrador".</TextBlock>
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="💾 LiteDB: file locked al abrir el programa" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">Hay otra instancia del Plugin Manager ya abierta. Ciérrala desde el Administrador de Tareas buscando "ReaperPluginManager".</TextBlock>
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="🔌 Win32 error 126 al cargar un plugin en el sandbox" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                        <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap">El plugin es de 32-bit (x86) en un sistema 64-bit. Busca la versión x64 del plugin en el sitio oficial del fabricante.</TextBlock>
                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
            <!-- FIN Panel Ayuda -->
        </Grid>

        <!-- ═══════════════════════════════════════════════ STATUS BAR ══ -->
        <Border Grid.Row="3" Background="#111111"
                BorderThickness="0,1,0,0" BorderBrush="#2A2A3E" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Mensaje de estado -->
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="#78909C" TextTrimming="CharacterEllipsis"/>

                <!-- Barra de progreso general -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            Margin="0,0,12,0" VerticalAlignment="Center"
                            Visibility="{Binding IsOperationRunning,
                                Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar Width="200" Height="4"
                                 Value="{Binding OverallProgress}"
                                 Foreground="{DynamicResource SecondaryHueMidBrush}"
                                 Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding OverallProgress, StringFormat='{}{0:F0}%'}"
                               FontSize="11" Foreground="#78909C" VerticalAlignment="Center"/>
                    <Button Command="{Binding CancelOperationCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Padding="4,2" Margin="8,0,0,0" Height="20">
                        <TextBlock Text="Cancelar" FontSize="10"/>
                    </Button>
                </StackPanel>

                <!-- Versión -->
                <TextBlock Grid.Column="2" Text="v1.0.0"
                           VerticalAlignment="Center" FontSize="11"
                           Foreground="#37474F"/>
            </Grid>
        </Border>
    </Grid>
</Window>
