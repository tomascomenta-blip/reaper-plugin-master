                                            <Run Text=" La app no funciona en macOS ni Linux."/>
                                        </TextBlock>
                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>

                            <!-- SECCIÓN 2: Compilar -->
                            <StackPanel x:Name="HelpSec2" Visibility="Collapsed">
                                <TextBlock Text="Compilar y ejecutar el programa"
                                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                           Foreground="White" Margin="0,0,0,6"/>
                                <TextBlock Text="Genera el .exe desde el código fuente con estos pasos"
                                           Foreground="#78909C" FontSize="13" Margin="0,0,0,20"/>
                                <!-- Paso 1 -->
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0">
                                            <TextBlock Text="1" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Clonar el repositorio" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                            <Border Background="#0A0A12" CornerRadius="4" Padding="12,10">
                                                <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#90CBF9" TextWrapping="Wrap">
                                                    git clone https://github.com/tomascomenta-blip/reaper-plugin-master.git&#xA;cd reaper-plugin-master
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                                <!-- Paso 2 -->
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0">
                                            <TextBlock Text="2" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Restaurar dependencias NuGet" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                            <Border Background="#0A0A12" CornerRadius="4" Padding="12,10">
                                                <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#90CBF9">dotnet restore ReaperPluginManager.csproj</TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                                <!-- Paso 3 -->
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0">
                                            <TextBlock Text="3" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Publicar como .exe portable (un solo archivo)" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
