                                </materialDesign:Card>
                                <!-- Fila 2 -->
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Windows 10 / 11 x64" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text="La app usa WPF, WinVerifyTrust y Windows Defender." FontSize="12" Foreground="#78909C"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#1B3A2A" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                            <TextBlock Text="REQUERIDO" FontSize="10" Foreground="{StaticResource SafeGreen}" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </materialDesign:Card>
                                <!-- Fila 3 -->
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="REAPER (cualquier versión reciente)" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text="El DAW donde se instalarán tus plugins." FontSize="12" Foreground="#78909C"/>
                                            <TextBlock Text="→ reaper.fm" FontSize="11" Foreground="{DynamicResource PrimaryHueLightBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#1B3A2A" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                            <TextBlock Text="REQUERIDO" FontSize="10" Foreground="{StaticResource SafeGreen}" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </materialDesign:Card>
                                <!-- Fila 4 -->
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Visual Studio 2022 Community" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text="Solo si quieres editar el código fuente." FontSize="12" Foreground="#78909C"/>
                                            <TextBlock Text="→ visualstudio.microsoft.com" FontSize="11" Foreground="{DynamicResource PrimaryHueLightBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#2A2A3E" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                            <TextBlock Text="OPCIONAL" FontSize="10" Foreground="#90A4AE" FontWeight="Bold"/>
