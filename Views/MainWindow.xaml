                                            <Run FontWeight="Bold" Text="Compatible con:" Foreground="White"/>
                                            <Run Text=" VST2 (.dll), VST3 (.vst3) y JSFX (.jsfx). Solo Windows 10/11 x64."/>
                                        </TextBlock>
                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>

                            <!-- SECCIÓN 1: Requisitos -->
                            <StackPanel x:Name="HelpSec1" Visibility="Collapsed">
                                <TextBlock Text="Requisitos del sistema"
                                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                           Foreground="White" Margin="0,0,0,6"/>
                                <TextBlock Text="Todo lo que necesitas antes de usar el programa"
                                           Foreground="#78909C" FontSize="13" Margin="0,0,0,20"/>
                                <!-- Fila 1 -->
                                <materialDesign:Card Background="{StaticResource CardDark}" Padding="16" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text=".NET SDK 8.0+" FontWeight="Bold" Foreground="White"/>
