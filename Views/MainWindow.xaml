                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Hash SHA-256"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding HashCheckPassed, Converter={StaticResource BoolToVisibility}}"
                                                   Foreground="{StaticResource SafeGreen}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Firma Digital"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SignatureSubject}"
                                                   FontSize="11" Foreground="#90A4AE"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Windows Defender"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DefenderThreatFound, Converter={StaticResource InverseBool}}"
                                                   Foreground="{StaticResource SafeGreen}"/>
                                    </Grid>
                                </StackPanel>
                            </materialDesign:Card>

                            <!-- Resultado sandbox -->
