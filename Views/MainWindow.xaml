                                    BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Music" Width="16" Height="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Instalar en REAPER" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="HelpNav5" Click="HelpNav_Click" Tag="5"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="12,8" Foreground="#78909C"
                                    BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShieldCheckOutline" Width="16" Height="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Escaneo de seguridad" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="HelpNav6" Click="HelpNav_Click" Tag="6"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="12,8" Foreground="#78909C"
                                    BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FrequentlyAskedQuestions" Width="16" Height="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Preguntas frecuentes" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Contenido de la sección de ayuda -->
                <Border Grid.Column="1" Background="{StaticResource BackgroundDark}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="32,28,32,32">

                            <!-- SECCIÓN 0: ¿Qué es esto? -->
                            <StackPanel x:Name="HelpSec0" Visibility="Visible">
                                <TextBlock Text="¿Qué es REAPER Plugin Manager?"
                                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                           Foreground="White" Margin="0,0,0,6"/>
                                <TextBlock Text="Gestor visual de plugins VST, VST3 y JSFX para REAPER"
                                           Foreground="#78909C" FontSize="13" Margin="0,0,0,20"/>
                                <TextBlock FontSize="13" Foreground="#B0BEC5" TextWrapping="Wrap"
                                           Margin="0,0,0,20" LineHeight="22">
                                    Esta aplicación te permite gestionar, instalar, escanear y organizar todos tus
                                    plugins de audio desde una sola ventana, sin mover archivos manualmente ni
                                    configurar REAPER plugin a plugin.
                                </TextBlock>
                                <UniformGrid Rows="2" Columns="2" Margin="0,0,0,20">
                                    <materialDesign:Card Margin="0,0,8,8" Background="{StaticResource CardDark}" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="📦" FontSize="24" Margin="0,0,0,8"/>
                                            <TextBlock Text="Catálogo centralizado" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                                            <TextBlock Text="Todos tus plugins en una base de datos local con historial y metadatos." FontSize="12" Foreground="#78909C" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </materialDesign:Card>
                                    <materialDesign:Card Margin="0,0,0,8" Background="{StaticResource CardDark}" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="🛡️" FontSize="24" Margin="0,0,0,8"/>
                                            <TextBlock Text="Análisis de seguridad" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                                            <TextBlock Text="Escaneo con Windows Defender y verificación de firma digital." FontSize="12" Foreground="#78909C" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </materialDesign:Card>
                                    <materialDesign:Card Margin="0,0,8,0" Background="{StaticResource CardDark}" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="🚀" FontSize="24" Margin="0,0,0,8"/>
                                            <TextBlock Text="Instalación automática" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                                            <TextBlock Text="Copia los .dll o .vst3 al directorio correcto de REAPER con un clic." FontSize="12" Foreground="#78909C" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </materialDesign:Card>
                                    <materialDesign:Card Margin="0,0,0,0" Background="{StaticResource CardDark}" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="🎵" FontSize="24" Margin="0,0,0,8"/>
                                            <TextBlock Text="Integración con REAPER" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                                            <TextBlock Text="Detecta y usa la ruta de plugins de REAPER automáticamente." FontSize="12" Foreground="#78909C" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </UniformGrid>
                                <materialDesign:Card Background="#1B3A2A" Padding="14" Margin="0,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="{StaticResource SafeGreen}"
