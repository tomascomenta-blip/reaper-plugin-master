                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,16,0">
